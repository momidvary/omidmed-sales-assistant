# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.step*-backup/
.vercel

# Holoo Windows sync agent local/runtime data
/tools/holoo-sync-agent/config.json
/tools/holoo-sync-agent/.holoo-sync-agent/
/tools/holoo-sync-agent/*.dpapi
/tools/holoo-sync-agent/*.state.json
/tools/holoo-sync-agent/logs/
